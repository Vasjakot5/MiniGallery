    {
      "name": "Авторизация",
      "item": [
        {
          "name": "Вход",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "pm.collectionVariables.set(\"token\", response.token);\r",
                  "pm.collectionVariables.set(\"userId\", response.user.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "async function sha256(message) {\r",
                  "    const msgBuffer = new TextEncoder().encode(message);\r",
                  "    const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);\r",
                  "    const hashArray = Array.from(new Uint8Array(hashBuffer));\r",
                  "    const hashHex = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');\r",
                  "    return hashHex;\r",
                  "}\r",
                  "\r",
                  "const plainPassword = pm.request.body?.raw ? JSON.parse(pm.request.body.raw).password : pm.variables.get(\"password\");\r",
                  "\r",
                  "if (plainPassword) {\r",
                  "    sha256(plainPassword).then(hash => {\r",
                  "        pm.variables.set(\"password_hash\", hash);\r",
                  "        let body = JSON.parse(pm.request.body.raw);\r",
                  "        body.password = hash;\r",
                  "        pm.request.body.raw = JSON.stringify(body);\r",
                  "    });\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"name\": \"AdminMiniGallery\",\r\n    \"password\": \"AdminMiniGallery\"\r\n}",
              "options": {
